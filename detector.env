# ─── Modell ───────────────────────────────────────────────────
MODEL_PATH=/app/models/model.tflite
INPUT_W=224
INPUT_H=224
TENSOR_ARENA_KB=1400

# ─── Hálózat ──────────────────────────────────────────────────
FLASK_URL=http://host.docker.internal:5000/log
LISTEN_PORT=8080

# ─── Confidence ───────────────────────────────────────────────
# Alap küszöb — ez alatt sosem logolunk
CONFIDENCE_THRESH=0.90

# N-of-M szűrés: M egymást követő képkockából legalább N-nek
# kell ugyanazt a labelt adnia CONFIDENCE_THRESH felett.
# Ez kiszűri az egyszeri téves detekciót.
# Példa: CONFIRM_N=3 CONFIRM_M=5 → 5 képből 3 egyezés kell
CONFIRM_N=3
CONFIRM_M=5

# ─── Labelek ──────────────────────────────────────────────────
# A modell osztályainak SORRENDBEN kell szerepelniük, vesszővel elválasztva.
# LOG_LABELS:    ezekre küldünk logot a Flask szervernek
# SILENT_LABELS: felismeri, de NEM logol (pl. ember jelenléte)
LOG_LABELS=Patkány,Egér,Csótány,Hangya,Molylepke
SILENT_LABELS=Ember
